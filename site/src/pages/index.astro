---
import Base from "@/layouts/Base.astro";
import Search from "@/components/Search.astro";
import Terminal from "@/components/Terminal.astro";
import CustomiseAnimation from "@/components/CustomiseAnimation.astro";
import {
  getManifest,
  departmentLabel,
  departmentPitch,
} from "@/utils/skills";

const { skills, departments, totals } = getManifest();

const featuredSlugs = [
  "ship-feature",
  "full-security-audit",
  "release-to-prod",
  "marketing-weekly",
];
const featured = featuredSlugs
  .map((slug) => skills.find((s) => s.slug === slug))
  .filter((x): x is (typeof skills)[number] => Boolean(x));
---

<Base title="skillskit.dev">
  <section class="hero">
    <p class="eyebrow">Software Development Agent Stack · open source</p>
    <h1>Claude Code skills for every department —<br /><span class="hero-accent">install in 30 seconds.</span></h1>
    <p class="lede">
      A curated library of <strong>{totals.skills}</strong> production-ready skills across
      <strong>{totals.departments}</strong> departments. Engineering, security, devops, infrastructure,
      QA, sales, marketing, internal comms. Plus <strong>{totals.orchestrators}</strong>
      workflow orchestrators that chain skills into end-to-end flows.
    </p>

    <div class="hero-install">
      <div class="hero-install-copy">
        <code>brew install skillskit &amp;&amp; skillskit install all</code>
        <button class="hero-copy-btn" type="button" data-copy="brew tap tahirraufkeeyu/tap && brew install skillskit && skillskit install all" aria-label="Copy install command">
          copy
        </button>
      </div>
      <p class="hero-install-note muted">
        One line. macOS and Linux via Homebrew.
        <a href="#install">Windows, curl, and manual install →</a>
      </p>
    </div>

    <div class="cta-row">
      <a class="btn btn-primary" href="#install">Install</a>
      <a class="btn btn-secondary" href="/departments">Browse departments</a>
      <a
        class="btn btn-secondary"
        href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas"
        target="_blank"
        rel="noopener">View on GitHub ↗</a
      >
    </div>
    <p class="hero-custom muted">
      Every skill ships a <strong>Customise for your organisation</strong> button — rewrite any
      skill for your stack via an LLM, fully in your browser. <a href="/settings">Add your
      OpenRouter key →</a>
    </p>
    <p class="stats subtle">
      {totals.skills} skills
      · {totals.bySafety.safe} safe
      · {totals.bySafety["writes-local"]} writes-local
      · {totals.bySafety["writes-shared"]} writes-shared
      · {totals.bySafety.destructive} destructive
    </p>
  </section>

  <section class="anim-pair" aria-label="How the kit runs and how skills get customised">
    <div class="anim-headline">
      <h2>Run it. Or rewrite it for your stack.</h2>
      <p class="muted">
        Left: how a skill runs end to end when you invoke it. Right: how the per-skill
        customizer rewrites it for your org in one click. Both are real flows.
      </p>
    </div>
    <div class="anim-grid">
      <Terminal />
      <CustomiseAnimation />
    </div>
  </section>

  <section id="install" class="install-section">
    <div class="install-head">
      <p class="eyebrow">Install</p>
      <h2>Pick your platform.</h2>
      <p class="muted">
        The <code>skillskit</code> CLI is a single cross-platform binary — macOS, Linux, Windows
        (amd64 + arm64) — with all {totals.skills} skills baked in. No runtime, no Node, no
        Python. Installs skills into <code>~/.claude/skills/</code>; also targets Cursor, Codex,
        and Gemini with <code>--host</code>.
      </p>
    </div>

    <div class="install-grid">
      <div class="install-card install-card-primary">
        <div class="install-card-head">
          <div class="install-card-title">
            <span class="platform-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
            </span>
            <h3>macOS &amp; Linux</h3>
          </div>
          <span class="install-chip">Recommended</span>
        </div>
        <p class="muted">Homebrew on macOS or Linuxbrew on Linux.</p>
        <pre class="install-snippet"><code>{`brew tap tahirraufkeeyu/tap
brew install skillskit
skillskit install all`}</code><button class="install-copy" type="button" data-copy="brew tap tahirraufkeeyu/tap && brew install skillskit && skillskit install all" aria-label="Copy">copy</button></pre>
        <p class="install-foot subtle">
          Upgrading? <code>brew upgrade skillskit &amp;&amp; skillskit update</code>
        </p>
      </div>

      <div class="install-card">
        <div class="install-card-head">
          <div class="install-card-title">
            <span class="platform-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.48L10.05 4.5v6.85H3V5.48zm0 13.04L10.05 19.5v-6.84H3v5.86zm7.85 1.09L21 21V13H10.85v6.61zm0-7.61H21V3l-10.15 1.39V12z"/></svg>
            </span>
            <h3>Windows</h3>
          </div>
          <span class="install-chip">Scoop</span>
        </div>
        <p class="muted">One-liner via the <a href="https://scoop.sh">Scoop</a> package manager.</p>
        <pre class="install-snippet"><code>{`scoop bucket add skillskit https://github.com/tahirraufkeeyu/scoop-bucket
scoop install skillskit
skillskit install all`}</code><button class="install-copy" type="button" data-copy="scoop bucket add skillskit https://github.com/tahirraufkeeyu/scoop-bucket; scoop install skillskit; skillskit install all" aria-label="Copy">copy</button></pre>
        <p class="install-foot subtle">
          Upgrading? <code>scoop update skillskit &amp;&amp; skillskit update</code>
        </p>
      </div>

      <div class="install-card">
        <div class="install-card-head">
          <div class="install-card-title">
            <span class="platform-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 10 12 4 17"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            </span>
            <h3>One-liner (no package manager)</h3>
          </div>
          <span class="install-chip">macOS / Linux</span>
        </div>
        <p class="muted">Grabs the latest release from GitHub, verifies SHA256, drops the binary on <code>PATH</code>.</p>
        <pre class="install-snippet"><code>{`curl -fsSL https://skillskit.dev/install | sh
skillskit install all`}</code><button class="install-copy" type="button" data-copy="curl -fsSL https://skillskit.dev/install | sh && skillskit install all" aria-label="Copy">copy</button></pre>
        <p class="install-foot subtle">
          CI runners, containers, any Unix without a package manager.
        </p>
      </div>

      <div class="install-card">
        <div class="install-card-head">
          <div class="install-card-title">
            <span class="platform-icon platform-icon-ps" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 5 14 12 6 19"/><line x1="13" y1="19" x2="19" y2="19"/></svg>
            </span>
            <h3>Windows — PowerShell</h3>
          </div>
          <span class="install-chip">No package manager</span>
        </div>
        <p class="muted">Same installer, PowerShell flavour. Adds <code>%LOCALAPPDATA%\Programs\skillskit</code> to your user <code>PATH</code>.</p>
        <pre class="install-snippet"><code>{`iwr https://skillskit.dev/install.ps1 -useb | iex
skillskit install all`}</code><button class="install-copy" type="button" data-copy="iwr https://skillskit.dev/install.ps1 -useb | iex; skillskit install all" aria-label="Copy">copy</button></pre>
        <p class="install-foot subtle">
          Open a new terminal after install so <code>PATH</code> picks up.
        </p>
      </div>
    </div>

    <div class="install-after">
      <h3>After install</h3>
      <div class="install-after-row">
        <pre class="install-snippet"><code>{`skillskit install developers     # one department
skillskit install --host cursor all  # target Cursor instead
skillskit list                   # see what's installed
skillskit search "code review"   # find skills by keyword
skillskit update                 # re-sync to the latest
skillskit remove all             # uninstall everything this kit shipped
skillskit --help                 # full command list`}</code></pre>
        <div class="install-after-note">
          <p>
            Skills are embedded in the binary. Upgrading the CLI (via <code>brew upgrade</code>,
            <code>scoop update</code>, or re-running the curl installer) upgrades the skills;
            <code>skillskit update</code> re-syncs any already-installed skills to the new
            versions without touching custom skills or other tools.
          </p>
          <p class="muted">
            Don't want to use the CLI? The legacy <code>git clone &amp;&amp; ./install.sh</code>
            path is still supported —
            <a href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas#for-the-old-school-git-clone--installsh" target="_blank" rel="noopener">see the README</a>.
          </p>
        </div>
      </div>
    </div>

    <div class="install-alt">
      <details>
        <summary>Other install options</summary>
        <ul>
          <li>
            <strong>GitHub Releases</strong> — download the matching archive from
            <a href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas/releases/latest" target="_blank" rel="noopener">the latest release</a>
            and drop the binary on your <code>PATH</code>. Checksums in <code>checksums.txt</code>.
          </li>
          <li>
            <strong>go install</strong> (requires Go 1.22+) —
            <code>go install github.com/tahirraufkeeyu/software-development-agent-stack--sdas@latest</code>
            produces a binary without the embedded skills; you'll need to install skills from
            source. Use this only if you're contributing to the CLI.
          </li>
          <li>
            <strong>Git clone + install.sh</strong> (legacy) — the shell-script installer from the
            repo root still works identically. Useful for air-gapped environments or editing
            skills locally before installing.
          </li>
        </ul>
      </details>
    </div>
  </section>

  <section>
    <h2>Find a skill</h2>
    <Search />
  </section>

  <section>
    <h2>What this is</h2>
    <p>
      Most "AI for teams" content stops at "install Claude Code and good luck." The gap is the
      layer that makes Claude behave like a reliable teammate — one that triggers on the right
      work, follows the same process your senior people would, and produces output consistent
      with what your team already ships.
    </p>
    <p>
      Skills are that layer. A skill is a single Markdown file (<code>SKILL.md</code>) that
      declares when it should run, the exact procedure, concrete examples, constraints, and
      quality checks. Claude Code auto-triggers the right one based on your natural-language
      request — no slash commands to memorise.
    </p>
    <p>
      Everything here is MIT licensed. Clone, install, customise, share.
    </p>
  </section>

  <section>
    <h2>Departments</h2>
    <div class="grid-auto">
      {
        departments.map((d) => (
          <a class="card card-link dept-card" href={`/departments/${d.slug}`}>
            <div class="dept-head">
              <h3>{departmentLabel(d.slug)}</h3>
              <span class="dept-count">{d.skillCount} skills</span>
            </div>
            <p class="muted">{departmentPitch(d.slug)}</p>
            {d.orchestratorCount > 0 ? (
              <p class="dept-orch">
                <span class="orch-dot" />
                {d.orchestratorCount} orchestrator{d.orchestratorCount === 1 ? "" : "s"} — {d.orchestrators.join(", ")}
              </p>
            ) : null}
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Featured orchestrators</h2>
    <p class="muted">
      End-to-end flows that chain multiple skills. Each department ships at least one.
    </p>
    <div class="grid-auto">
      {
        featured.map((s) => (
          <a class="card card-link feat-card" href={`/skills/${s.slug}`}>
            <h3>{s.name}</h3>
            <p class="muted" style="font-size:0.95rem;">{s.description}</p>
            <p class="feat-chains">
              <span class="subtle">chains: </span>
              {s.chains.map((c, i) => (
                <>
                  <code>{c}</code>
                  {i < s.chains.length - 1 ? " → " : ""}
                </>
              ))}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <section>
    <h2>See it in action</h2>
    <p>
      Two worked walkthroughs in the repo show the kit end-to-end, with the exact user prompt,
      the skill Claude matched, what Claude did, and files changed:
    </p>
    <ul>
      <li>
        <a
          href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas/blob/main/examples/simple-101/how-to.md"
          target="_blank"
          rel="noopener">Simple 101 — setup + first skill</a
        > (15 min). Covers Claude Code, the VS Code extension, GitHub Copilot, and Codex CLI. Ships a
        FastAPI <code>/hello</code> endpoint.
      </li>
      <li>
        <a
          href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas/blob/main/examples/developers/how-to.md"
          target="_blank"
          rel="noopener">Developers — full end-to-end</a
        > (45 min). Nine skills on a real public repo (node-express-boilerplate). One shipped
        feature, one merged PR.
      </li>
    </ul>
  </section>
</Base>

<script>
  /**
   * Copy-to-clipboard wiring for the hero install bar + every install
   * card's snippet. Handles the navigator.clipboard path and falls
   * back to the old execCommand('copy') for environments where
   * writeText is blocked (e.g. non-HTTPS preview deploys).
   */
  function initCopyButtons() {
    document.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy ?? "";
        if (!text) return;

        const ok = await copyText(text);
        const originalLabel = btn.textContent;

        btn.classList.toggle("copied", ok);
        btn.textContent = ok ? "copied ✓" : "failed";

        setTimeout(() => {
          btn.textContent = originalLabel;
          btn.classList.remove("copied");
        }, 1800);
      });
    });
  }

  async function copyText(text: string): Promise<boolean> {
    if (navigator.clipboard?.writeText) {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        /* fall through */
      }
    }
    try {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.position = "absolute";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      const ok = document.execCommand("copy");
      document.body.removeChild(ta);
      return ok;
    } catch {
      return false;
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCopyButtons);
  } else {
    initCopyButtons();
  }
</script>

<style>
  .hero {
    padding: var(--space-8) 0 var(--space-12);
    max-width: 48rem;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--space-4);
  }
  .hero h1 {
    font-size: 2.25rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-4);
  }
  @media (min-width: 48rem) {
    .hero h1 {
      font-size: 2.75rem;
    }
  }
  .lede {
    font-size: 1.15rem;
    color: var(--fg-muted);
    margin: 0 0 var(--space-6);
    line-height: 1.55;
  }
  .lede strong {
    color: var(--fg);
    font-weight: 600;
  }
  .cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.6rem 1.1rem;
    font-size: 0.95rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
  }
  .btn-primary:hover {
    background: var(--accent-strong);
    color: var(--bg);
  }
  .btn-secondary {
    background: transparent;
    border-color: var(--border-strong);
    color: var(--fg);
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .stats {
    font-family: var(--font-mono);
    margin: 0;
  }
  .hero-accent {
    color: var(--accent);
  }

  .hero-install {
    margin: var(--space-6) 0;
  }
  .hero-install-copy {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    background: var(--bg-elev-1);
    overflow: hidden;
    max-width: 100%;
  }
  .hero-install-copy code {
    display: block;
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    background: transparent;
    border: 0;
    border-radius: 0;
    color: var(--fg);
    white-space: nowrap;
    overflow-x: auto;
  }
  .hero-copy-btn {
    flex-shrink: 0;
    font: inherit;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0 var(--space-4);
    background: var(--bg-elev-2);
    border: 0;
    border-left: 1px solid var(--border);
    color: var(--fg-muted);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }
  .hero-copy-btn:hover {
    background: var(--accent);
    color: var(--bg);
  }
  .hero-copy-btn.copied {
    background: var(--success);
    color: var(--bg);
  }
  .hero-install-note {
    margin: var(--space-3) 0 0;
    font-size: 0.9rem;
  }

  .hero-custom {
    margin: var(--space-5) 0 0;
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 44rem;
  }
  .hero-custom strong {
    color: var(--fg);
  }

  /* =========================================================
     Install section — the big platform-by-platform CTA.
     Grid of cards, each with a platform heading, explanation,
     copy-pasteable snippet, and an upgrade hint in the footer.
     ========================================================= */

  .install-section {
    margin: var(--space-12) 0;
    scroll-margin-top: var(--space-8); /* clearance for sticky nav when anchored via #install */
  }
  .install-head {
    margin-bottom: var(--space-6);
    max-width: 52rem;
  }
  .install-head .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--space-2);
  }
  .install-head h2 {
    margin: 0 0 var(--space-3);
  }

  .install-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 48rem) {
    .install-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .install-card {
    background: var(--bg-elev-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
  }
  .install-card-primary {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    background: color-mix(in srgb, var(--accent) 5%, var(--bg-elev-1));
  }
  .install-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .install-card-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
  }
  .platform-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    color: var(--fg-muted);
    flex-shrink: 0;
  }
  .platform-icon svg {
    width: 100%;
    height: 100%;
  }
  .install-card-primary .platform-icon {
    color: var(--accent);
  }
  .platform-icon-ps {
    color: #1a7bd6;
  }
  .install-card h3 {
    margin: 0;
    font-size: 1.1rem;
  }
  .install-chip {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    padding: 0.1em 0.6em;
    border-radius: 999px;
  }
  .install-card-primary .install-chip {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .install-card p.muted {
    margin: 0 0 var(--space-3);
    font-size: 0.95rem;
  }

  .install-snippet {
    position: relative;
    margin: 0 0 var(--space-3);
    padding: var(--space-4) var(--space-5);
    padding-right: 4.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.55;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }
  .install-snippet code {
    background: transparent;
    border: 0;
    padding: 0;
    font-size: inherit;
    white-space: pre;
  }
  .install-copy {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    font: inherit;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.3em 0.7em;
    background: var(--bg-elev-2);
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
  }
  .install-copy:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .install-copy.copied {
    background: var(--success);
    color: var(--bg);
