---
/**
 * HeroAnimation.astro — decorative scene for the hero's right column.
 *
 * A purely visual illustration of the product's mental model:
 *   skill labels drift in from the edges and are absorbed into a brain
 *   (the user's Claude Code setup with skills loaded). The brain
 *   connects down to a 3-stage system (build / test / ship) where a
 *   dot cycles through to suggest a working pipeline. A coffee cup
 *   in the corner sets the tone — "sit back, the agents are working."
 *
 * Constraints:
 * - Pure inline SVG + CSS keyframes. No external library, no GIF.
 * - Scales to container width; portrait aspect so it fits the empty
 *   space to the right of the hero copy.
 * - aria-hidden — purely decorative.
 * - Honors prefers-reduced-motion: locks to a static composition
 *   (skills visible at rest, no movement).
 */
---

<div class="hero-anim" aria-hidden="true">
  <!-- SKILL STREAM — labels drift from edges toward the brain. -->
  <div class="skill-stream">
    <span class="skill skill-1"><code>code-review</code></span>
    <span class="skill skill-2"><code>security-audit</code></span>
    <span class="skill skill-3"><code>api-design</code></span>
    <span class="skill skill-4"><code>deploy</code></span>
    <span class="skill skill-5"><code>commit-message</code></span>
    <span class="skill skill-6"><code>status-update</code></span>
    <span class="skill skill-7"><code>proposal-writer</code></span>
    <span class="skill skill-8"><code>pentest-report</code></span>
  </div>

  <!-- BRAIN — gentle pulse + glow aura. -->
  <svg class="brain" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id="brainGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.35"></stop>
        <stop offset="60%" stop-color="currentColor" stop-opacity="0.08"></stop>
        <stop offset="100%" stop-color="currentColor" stop-opacity="0"></stop>
      </radialGradient>
    </defs>
    <circle class="brain-aura" cx="60" cy="60" r="55" fill="url(#brainGlow)"></circle>
    <g
      class="brain-path"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <!-- Left hemisphere (Lucide-style brain, scaled to 120x120). -->
      <path
        d="M60 30a15 15 0 0 0 -30 0 12 12 0 0 0 -10 20 12 12 0 0 0 2 22 12 12 0 0 0 8 20 12 12 0 0 0 30 6 z"
      ></path>
      <!-- Right hemisphere, mirrored. -->
      <path
        d="M60 30a15 15 0 0 1 30 0 12 12 0 0 1 10 20 12 12 0 0 1 -2 22 12 12 0 0 1 -8 20 12 12 0 0 1 -30 6"
      ></path>
      <!-- Central valley suggesting the brain's fold. -->
      <path d="M60 30 V98" opacity="0.45"></path>
      <!-- Two fold lines per hemisphere. -->
      <path d="M40 50 Q50 56 42 66" opacity="0.45"></path>
      <path d="M80 50 Q70 56 78 66" opacity="0.45"></path>
      <path d="M38 78 Q50 82 44 90" opacity="0.45"></path>
      <path d="M82 78 Q70 82 76 90" opacity="0.45"></path>
    </g>
    <!-- Spark nodes inside the brain that flicker as skills land. -->
    <g class="sparks" fill="currentColor">
      <circle class="spark spark-1" cx="48" cy="55" r="2"></circle>
      <circle class="spark spark-2" cx="72" cy="50" r="2"></circle>
      <circle class="spark spark-3" cx="55" cy="75" r="2"></circle>
      <circle class="spark spark-4" cx="68" cy="82" r="2"></circle>
      <circle class="spark spark-5" cx="60" cy="62" r="2.5"></circle>
    </g>
  </svg>

  <!-- Connector from brain to system. -->
  <div class="connector" aria-hidden="true">
    <span class="pulse-line"></span>
  </div>

  <!-- ASSEMBLY BELT — shaped, colored packages travel left-to-right
       and burst into confetti at the end. Each package has its own
       shape, color, and short label (dev / sec / obs / qa / mob /
       infra). The belt rail + roller ticks below sell the "conveyor"
       read. -->
  <div class="belt" aria-hidden="true">
    <!-- Pulleys at both ends (with a spinning inner ring). -->
    <div class="pulley pulley-left"></div>
    <div class="pulley pulley-right"></div>
    <!-- Belt body — rounded pill between the pulleys, with diagonal
         stripes animating right-to-left inside to suggest motion. -->
    <div class="belt-body">
      <div class="belt-stripes"></div>
    </div>

    <!-- DEVELOPMENT — rounded square in dept-developers blue. -->
    <div class="package pkg-dev" style="--d: 0s;">
      <svg class="pkg-shape" viewBox="0 0 28 22">
        <rect x="1" y="1" width="26" height="20" rx="4" fill="currentColor" opacity="0.95"/>
        <text x="14" y="15" text-anchor="middle" font-size="9" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="#0b0d10">dev</text>
      </svg>
      <span class="conf c1"></span><span class="conf c2"></span>
      <span class="conf c3"></span><span class="conf c4"></span><span class="conf c5"></span>
    </div>

    <!-- SECURITY — pentagonal shield in dept-security coral. -->
    <div class="package pkg-sec" style="--d: 2s;">
      <svg class="pkg-shape" viewBox="0 0 28 22">
        <path d="M14 1 L27 5 V13 Q27 19 14 21 Q1 19 1 13 V5 Z" fill="currentColor" opacity="0.95"/>
        <text x="14" y="15" text-anchor="middle" font-size="9" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-weight="700" fill="#0b0d10">sec</text>
      </svg>
      <span class="conf c1"></span><span class="conf c2"></span>
      <span class="conf c3"></span><span class="conf c4"></span><span class="conf c5"></span>
    </div>

    <!-- OBSERVABILITY — bar-chart shape in dept-internal-comms cyan. -->
    <div class="package pkg-obs" style="--d: 4s;">
      <svg class="pkg-shape" viewBox="0 0 28 22">
        <rect x="1" y="1" width="26" height="20" rx="3" fill="currentColor" opacity="0.2"/>
        <rect x="4"  y="13" width="4" height="7"  fill="currentColor"/>
        <rect x="10" y="9"  width="4" height="11" fill="currentColor"/>
        <rect x="16" y="5"  width="4" height="15" fill="currentColor"/>
        <rect x="22" y="11" width="4" height="9"  fill="currentColor"/>
      </svg>
      <span class="conf c1"></span><span class="conf c2"></span>
      <span class="conf c3"></span><span class="conf c4"></span><span class="conf c5"></span>
    </div>

    <!-- QUALITY — diamond with checkmark in dept-devops mint. -->
    <div class="package pkg-qa" style="--d: 6s;">
      <svg class="pkg-shape" viewBox="0 0 28 22">
        <path d="M14 1 L27 11 L14 21 L1 11 Z" fill="currentColor" opacity="0.95"/>
        <path d="M9 11 L13 15 L19 8" stroke="#0b0d10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      <span class="conf c1"></span><span class="conf c2"></span>
      <span class="conf c3"></span><span class="conf c4"></span><span class="conf c5"></span>
    </div>

    <!-- MOBILE — tall phone outline in dept-qa lavender. -->
    <div class="package pkg-mob" style="--d: 8s;">
      <svg class="pkg-shape" viewBox="0 0 22 22">
        <rect x="4" y="1" width="14" height="20" rx="3" fill="currentColor" opacity="0.95"/>
        <rect x="9" y="3.5" width="4" height="0.8" rx="0.4" fill="#0b0d10" opacity="0.6"/>
        <circle cx="11" cy="18.5" r="1" fill="#0b0d10" opacity="0.5"/>
      </svg>
      <span class="conf c1"></span><span class="conf c2"></span>
      <span class="conf c3"></span><span class="conf c4"></span><span class="conf c5"></span>
    </div>

    <!-- INFRASTRUCTURE — isometric cube in dept-infrastructure amber. -->
    <div class="package pkg-infra" style="--d: 10s;">
      <svg class="pkg-shape" viewBox="0 0 28 22">
        <path d="M14 1 L26 6 L14 11 L2 6 Z"  fill="currentColor" opacity="0.95"/>
        <path d="M2 6 L2 16 L14 21 L14 11 Z" fill="currentColor" opacity="0.75"/>
        <path d="M14 11 L14 21 L26 16 L26 6 Z" fill="currentColor" opacity="0.55"/>
      </svg>
      <span class="conf c1"></span><span class="conf c2"></span>
      <span class="conf c3"></span><span class="conf c4"></span><span class="conf c5"></span>
    </div>
  </div>

</div>

<style>
  .hero-anim {
    position: relative;
    width: 100%;
    max-width: 32rem;
    aspect-ratio: 4 / 5;
    min-height: 28rem;
    margin: 0 auto;
    color: var(--fg);
    /* No border, no container background — the scene sits directly
       on the page and its edges fade into the page background via an
       alpha mask. */
    -webkit-mask-image: radial-gradient(
      ellipse 75% 80% at 50% 45%,
      black 55%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 75% 80% at 50% 45%,
      black 55%,
      transparent 100%
    );
  }

  /* ------------------------------------------------------------------ */
  /* BRAIN                                                              */
  /* ------------------------------------------------------------------ */

  .brain {
    position: absolute;
    top: 28%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44%;
    height: auto;
    color: var(--accent);
    animation: brainPulse 4s ease-in-out infinite;
  }
  @keyframes brainPulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      filter: drop-shadow(0 0 0 transparent);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.03);
      filter: drop-shadow(0 0 12px color-mix(in srgb, var(--accent) 40%, transparent));
    }
  }
  .brain-aura {
    animation: auraPulse 4s ease-in-out infinite;
  }
  @keyframes auraPulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  /* Inner sparks flicker out of sync with the pulse. */
  .spark {
    opacity: 0.4;
    animation: sparkBlink 2.4s ease-in-out infinite;
  }
  .spark-1 { animation-delay: 0s; }
  .spark-2 { animation-delay: 0.5s; }
  .spark-3 { animation-delay: 1s; }
  .spark-4 { animation-delay: 1.5s; }
  .spark-5 { animation-delay: 0.25s; }
  @keyframes sparkBlink {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* ------------------------------------------------------------------ */
  /* SKILL STREAM                                                       */
  /* ------------------------------------------------------------------ */

  .skill-stream {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .skill {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.22em 0.7em;
    white-space: nowrap;
    /* translate(-50%, -50%) keeps the label centered on its top/left
       anchor; scale shrinks it as it "dissolves" into the brain. */
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.85);
    animation: skillDrift 7s ease-in-out infinite;
  }
  .skill code {
    font-size: 1em;
    color: var(--accent);
    background: transparent;
    padding: 0;
  }

  /* Spawn positions + delays for each skill so the viewer always has
     2–3 labels visible at any time, staggered around the brain. */
  .skill-1 { top: 14%; left: 20%; animation-delay: 0s;   }
  .skill-2 { top: 9%;  left: 74%; animation-delay: 0.9s; }
  .skill-3 { top: 24%; left: 88%; animation-delay: 1.8s; }
  .skill-4 { top: 44%; left: 14%; animation-delay: 2.6s; }
  .skill-5 { top: 44%; left: 82%; animation-delay: 3.4s; }
  .skill-6 { top: 20%; left: 8%;  animation-delay: 4.2s; }
  .skill-7 { top: 32%; left: 92%; animation-delay: 5.0s; }
  .skill-8 { top: 10%; left: 50%; animation-delay: 5.8s; }

  @keyframes skillDrift {
    0%, 6%   { opacity: 0; transform: translate(-50%, -50%) scale(0.85); }
    14%      { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    65%      { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    82%      { opacity: 0.35; transform: translate(-50%, -50%) scale(0.55); }
    100%     { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
  }

  /* ------------------------------------------------------------------ */
  /* CONNECTOR (brain -> system)                                        */
  /* ------------------------------------------------------------------ */

  .connector {
    position: absolute;
    left: 50%;
    top: 48%;
    width: 2px;
    height: 14%;
    transform: translateX(-50%);
    overflow: hidden;
  }
  .connector::before {
    content: "";
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .pulse-line {
    position: absolute;
    top: -40%;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--accent) 50%,
      transparent 100%
    );
    animation: pulseDown 1.8s linear infinite;
  }
  @keyframes pulseDown {
    0%   { top: -50%; opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* ------------------------------------------------------------------ */
  /* ASSEMBLY BELT — pulleys + moving-stripe belt + packages            */
  /* ------------------------------------------------------------------ */

  .belt {
    position: absolute;
    left: 6%;
    right: 6%;
    bottom: 12%;
    height: 3.25rem;
    /* Total loop time used for all sub-animations so they stay in
       phase across packages + belt stripes. Increased from the
       earlier 7.2s to 12s per user feedback (too fast). */
  }

  /* The belt body is a rounded pill connecting the two pulleys. */
  .belt-body {
    position: absolute;
    top: 50%;
    left: 0.65rem;        /* starts inside the left pulley */
    right: 0.65rem;       /* ends inside the right pulley */
    height: 1.4rem;
    transform: translateY(-50%);
    background: var(--bg-elev-2);
    border: 1px solid color-mix(in srgb, var(--fg-muted) 55%, transparent);
    border-radius: 999px;
    overflow: hidden;
  }

  /* Diagonal stripes inside the belt, sliding right-to-left so the
     belt reads as carrying things to the right. */
  .belt-stripes {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -60deg,
      color-mix(in srgb, var(--fg-muted) 32%, transparent) 0 2px,
      transparent 2px 10px
    );
    background-size: 14px 100%;
    animation: beltMove 1.8s linear infinite;
  }
  @keyframes beltMove {
    from { background-position: 0 0; }
    to   { background-position: -28px 0; }
  }

  /* Pulleys — circles at each end of the belt with a dashed inner
     ring that rotates, so the wheels read as spinning. */
  .pulley {
    position: absolute;
    top: 50%;
    width: 1.65rem;
    height: 1.65rem;
    transform: translateY(-50%);
    border-radius: 999px;
    background: var(--bg-elev-2);
    border: 1.5px solid color-mix(in srgb, var(--fg-muted) 65%, transparent);
    box-shadow: inset 0 0 0 2px color-mix(in srgb, var(--fg-subtle) 22%, transparent);
  }
  .pulley-left  { left: 0; }
  .pulley-right { right: 0; }
  .pulley::before {
    content: "";
    position: absolute;
    inset: 0.3rem;
    border-radius: 999px;
    border: 1.2px dashed color-mix(in srgb, var(--fg-muted) 80%, transparent);
    animation: pulleySpin 1.8s linear infinite;
  }
  @keyframes pulleySpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Each package travels from just off-left to ~88% right, then
     scales + fades (the "pop"). Packages share one 12s animation
     but get their own --d delay so a new package arrives every 2s.
     animation-fill-mode: backwards keeps them at the 0% frame
     (left: -12%, opacity: 0) *before* their delay fires, which
     fixes the first-load glitch where icons appeared stuck at x=0
     until each animation first kicked in. */
  .package {
    position: absolute;
    top: 0.05rem;           /* ride on top of the belt */
    left: -12%;
    opacity: 0;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pkgSlide 12s cubic-bezier(0.45, 0.1, 0.85, 0.55) infinite;
    animation-delay: var(--d, 0s);
    animation-fill-mode: backwards;
  }
  .pkg-shape {
    width: 100%;
    height: 100%;
    animation: pkgBurstShape 12s cubic-bezier(0.45, 0.1, 0.85, 0.55) infinite;
    animation-delay: var(--d, 0s);
    animation-fill-mode: backwards;
  }

  /* Per-package colors read via currentColor on the SVG. */
  .pkg-dev   { color: var(--dept-developers); }
  .pkg-sec   { color: var(--dept-security); }
  .pkg-obs   { color: var(--dept-internal-comms); }
  .pkg-qa    { color: var(--dept-devops); }
  .pkg-mob   { color: var(--dept-qa); }
  .pkg-infra { color: var(--dept-infrastructure); }

  @keyframes pkgSlide {
    0%   { left: -12%; opacity: 0; }
    4%   { opacity: 1; }
    82%  { left: 88%; opacity: 1; }
    86%  { left: 92%; opacity: 0; }
    100% { left: 92%; opacity: 0; }
  }
  @keyframes pkgBurstShape {
    0%, 80%  { transform: scale(1); filter: none; }
    83%      { transform: scale(1.22); filter: drop-shadow(0 0 8px currentColor); }
    87%      { transform: scale(0.25); opacity: 0; }
    100%     { transform: scale(0); opacity: 0; }
  }

  /* Confetti: 5 small colored squares sprayed outward at burst time.
     Each piece has its own --dx / --dy direction vector so they fan
     out rather than overlap. Color inherited via currentColor. */
  .conf {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 4px;
    height: 4px;
    background: currentColor;
    border-radius: 1px;
    opacity: 0;
    animation: confettiBurst 12s cubic-bezier(0.2, 0.6, 0.3, 1) infinite;
    animation-delay: var(--d, 0s);
    animation-fill-mode: backwards;
  }
  .conf.c1 { --dx: -20px; --dy: -24px; --rot: 140deg; }
  .conf.c2 { --dx:  18px; --dy: -28px; --rot: -120deg; }
  .conf.c3 { --dx:  26px; --dy: -12px; --rot: 200deg; }
  .conf.c4 { --dx: -24px; --dy:  -8px; --rot: -80deg; }
  .conf.c5 { --dx:   4px; --dy: -32px; --rot: 60deg; }

  @keyframes confettiBurst {
    0%, 80%  { opacity: 0; transform: translate(-50%, -50%) scale(0.4) rotate(0deg); }
    84%      { opacity: 1; transform: translate(-50%, -50%) scale(1) rotate(0deg); }
    100%     {
      opacity: 0;
      transform:
        translate(calc(-50% + var(--dx, 0px)), calc(-50% + var(--dy, 0px)))
        scale(0.6)
        rotate(var(--rot, 180deg));
    }
  }

  /* ------------------------------------------------------------------ */
  /* RESPONSIVE + REDUCED MOTION                                        */
  /* ------------------------------------------------------------------ */

  /* Hide the whole scene below the breakpoint where we can show it
     side-by-side with the hero copy. Mobile hero already tells the
     story in text; we don't want to stack a decorative box below. */
  @media (max-width: 63.99rem) {
    .hero-anim {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brain,
    .brain-aura,
    .spark,
    .skill,
    .pulse-line,
    .belt-stripes,
    .pulley::before,
    .package,
    .pkg-shape,
    .conf {
      animation: none !important;
    }
    .skill {
      opacity: 1;
    }
    .brain {
      transform: translate(-50%, -50%);
    }
    /* Freeze 3 packages evenly along the belt; hide the rest. */
    .pkg-dev   { left: 15%; opacity: 1; }
    .pkg-sec   { left: 42%; opacity: 1; }
    .pkg-obs   { left: 68%; opacity: 1; }
    .pkg-qa, .pkg-mob, .pkg-infra { opacity: 0; }
    .conf { opacity: 0; }
  }
</style>
