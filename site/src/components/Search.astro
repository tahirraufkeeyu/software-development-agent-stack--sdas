---
/**
 * Search component — client-side only.
 *
 * Loads Pagefind from /_pagefind/ (generated post-build by the pagefind
 * CLI; see package.json build script). In development the /_pagefind/
 * directory doesn't exist, so the search input shows a hint that search
 * only works in production builds.
 *
 * Two variants:
 *   inline (default) — full-width, hint line below, used on standalone
 *                      pages if we ever want a big search target.
 *   nav              — compact version designed to live inside the
 *                      primary nav bar. No hint line, narrower default
 *                      width, results render as an absolute dropdown.
 *
 * Either way, only one instance can live on a page because the script
 * looks up its elements by fixed IDs (#skillskit-search-input /
 * #skillskit-search-results). The inline section on the homepage was
 * removed in favour of the nav instance, so every page now uses the
 * nav variant via Nav.astro.
 */

interface Props {
  variant?: "inline" | "nav";
}

const { variant = "inline" } = Astro.props;
const isNav = variant === "nav";
---

<div class:list={["search", isNav && "search-nav"]} id="skillskit-search">
  <label class="sr-only" for="skillskit-search-input">Search skills</label>
  <input
    type="search"
    id="skillskit-search-input"
    placeholder={isNav ? "Search 64 skills…" : "Search skills... (try 'code review' or 'prometheus')"}
    autocomplete="off"
    spellcheck="false"
  />
  {
    !isNav ? (
      <div class="hint subtle" id="skillskit-search-hint">
        Powered by Pagefind · ctrl+/ to focus
      </div>
    ) : (
      <div class="hint sr-only" id="skillskit-search-hint" aria-live="polite"></div>
    )
  }
  <ul class="results" id="skillskit-search-results" role="listbox" hidden></ul>
</div>

<style>
  .search {
    position: relative;
    max-width: 40rem;
    margin: 0 0 var(--space-8);
  }
  /* Nav variant: narrower, no bottom margin, results pop as a dropdown. */
  .search.search-nav {
    max-width: none;
    margin: 0;
    width: 100%;
  }
  input[type="search"] {
    width: 100%;
    font: inherit;
    font-size: 1rem;
    padding: 0.75rem 1rem;
    background: var(--bg-elev-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg);
    transition: border-color 120ms ease, background 120ms ease;
  }
  .search-nav input[type="search"] {
    font-size: 0.9rem;
    padding: 0.5rem 0.85rem 0.5rem 2.2rem;
    background: var(--bg-elev-2);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23888' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='7'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>");
    background-repeat: no-repeat;
    background-position: 0.65rem center;
    background-size: 0.95rem 0.95rem;
    border-radius: 999px;
  }
  input[type="search"]:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg-elev-2);
  }
  input[type="search"]::placeholder {
    color: var(--fg-subtle);
  }
  .hint {
    margin-top: var(--space-2);
    font-size: 0.8rem;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .results {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0;
    display: grid;
    gap: var(--space-2);
  }
  /* Nav variant: float results below the input as a dropdown. */
  .search-nav .results {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    margin: 0;
    z-index: 20;
    background: var(--bg-elev-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 48px -18px rgba(0, 0, 0, 0.45);
    padding: var(--space-2);
    max-height: 70vh;
    overflow-y: auto;
  }
  .results[hidden] {
    display: none;
  }
  .results :global(li) {
    background: var(--bg-elev-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }
  .search-nav .results :global(li) {
    border: 0;
    border-radius: var(--radius-sm, 6px);
    padding: var(--space-2) var(--space-3);
    background: transparent;
  }
  .search-nav .results :global(li:hover),
  .search-nav .results :global(li:focus-within) {
    background: var(--bg-elev-2);
  }
  .results :global(a) {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .results :global(.r-title) {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: var(--space-1);
  }
  .search-nav .results :global(.r-title) {
    font-size: 0.88rem;
  }
  .results :global(.r-meta) {
    font-size: 0.75rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    margin-bottom: var(--space-1);
  }
  .results :global(.r-excerpt) {
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .search-nav .results :global(.r-excerpt) {
    font-size: 0.8rem;
    line-height: 1.4;
  }
  .results :global(.r-excerpt mark) {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--fg);
    padding: 0 0.15em;
    border-radius: 2px;
  }
  .results :global(.r-empty) {
    color: var(--fg-muted);
    font-style: italic;
  }
</style>

<script>
  // Pagefind UI is loaded lazily — the index lives at /_pagefind/pagefind.js
  // after the post-build step. In dev the file doesn't exist at all, and
  // Vite would otherwise try to statically resolve the import during
  // dev-server transform (even with @vite-ignore). We dodge both issues
  // by short-circuiting in dev and computing the URL at runtime in prod.
  async function boot() {
    const input = document.getElementById("skillskit-search-input") as HTMLInputElement | null;
    const results = document.getElementById("skillskit-search-results") as HTMLUListElement | null;
    const hint = document.getElementById("skillskit-search-hint");
    if (!input || !results) return;

    // Ctrl+/ or Cmd+K focuses the search box.
    document.addEventListener("keydown", (e) => {
      const mod = e.ctrlKey || e.metaKey;
      if ((mod && e.key === "/") || (mod && e.key.toLowerCase() === "k")) {
        e.preventDefault();
        input.focus();
        input.select();
      }
    });

    // Close the nav dropdown when clicking outside of it.
    document.addEventListener("click", (e) => {
      const wrap = document.getElementById("skillskit-search");
      if (!wrap) return;
      if (wrap.contains(e.target as Node)) return;
      results.hidden = true;
    });

    // Re-show the dropdown when focusing the input if there are cached results.
    input.addEventListener("focus", () => {
      if (input.value.trim().length >= 2 && results.children.length > 0) {
        results.hidden = false;
      }
    });

    // Dev: Pagefind index doesn't exist, so don't try to import it.
    // import.meta.env.DEV is replaced at compile time with a boolean
    // literal, so the branch below is dead-code-eliminated in prod builds.
    if (import.meta.env.DEV) {
      if (hint) {
        hint.textContent =
          "Search is disabled in dev mode — run 'npm run build && npm run preview' to try it.";
      }
      return;
    }

    let pagefind: any = null;
    try {
      // Compute the URL at runtime so Vite's static analysis can't try
      // to resolve /_pagefind/pagefind.js during the dev transform.
      const pagefindUrl = new URL(
        "/_pagefind/pagefind.js",
        window.location.origin,
      ).href;
      // @ts-ignore - runtime artefact, no static types
      pagefind = await import(/* @vite-ignore */ pagefindUrl);
      await pagefind.options({ excerptLength: 30 });
    } catch (err) {
      console.error("[skillskit] pagefind failed to load", err);
      if (hint) {
        hint.textContent = "Search is temporarily unavailable.";
      }
      return;
    }

    let currentQuery = "";
    let timer: ReturnType<typeof setTimeout> | null = null;

    async function runSearch(q: string) {
      if (!q || q.length < 2) {
        results!.hidden = true;
        results!.innerHTML = "";
        return;
      }
      const r = await pagefind.search(q);
      if (q !== currentQuery) return; // race
      results!.hidden = false;
      if (r.results.length === 0) {
        results!.innerHTML = `<li class="r-empty">No matches for "${escapeHtml(q)}".</li>`;
        return;
      }
      const top = await Promise.all(r.results.slice(0, 10).map((x: any) => x.data()));
      results!.innerHTML = top
        .map((d: any) => {
          const title = escapeHtml(d.meta?.title ?? d.url);
          const dept = d.filters?.department?.[0] ?? "";
          const safety = d.filters?.safety?.[0] ?? "";
          return `
            <li>
              <a href="${d.url}">
                <div class="r-title">${title}</div>
                <div class="r-meta">${escapeHtml(dept)}${safety ? ` · ${escapeHtml(safety)}` : ""}</div>
                <div class="r-excerpt">${d.excerpt}</div>
              </a>
            </li>`;
        })
        .join("");
    }

    input.addEventListener("input", () => {
      const q = input.value.trim();
      currentQuery = q;
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => runSearch(q), 120);
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        input.value = "";
        currentQuery = "";
        results!.hidden = true;
        results!.innerHTML = "";
      }
    });
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
</script>
