---
/**
 * CustomiseModal.astro — the customizer dialog.
 *
 * Mounted once per skill page. Opens when any element with
 * [data-open-customizer] is clicked (typically the CustomiseButton on
 * the same page). Uses a native <dialog> for accessibility — Escape
 * closes, focus trap is automatic, backdrop is built in.
 *
 * This commit ships the UI shell with three states (form / generating
 * / done). The generating + done states' wiring to the LLM and the
 * diff view land in subsequent commits. The form state is fully
 * functional — prefills from localStorage and calls a stub submit
 * handler for now.
 */

interface Props {
  skillSlug: string;
  skillName: string;
  skillDescription: string;
  skillSafety: "safe" | "writes-local" | "writes-shared" | "destructive";
  skillMdPath: string; // repo-relative path to the original SKILL.md
  department: string;
}

const { skillSlug, skillName, skillDescription, skillSafety, skillMdPath, department } =
  Astro.props;
---

<dialog
  class="customiser"
  id="customiser"
  aria-labelledby="customiser-title"
  data-skill-slug={skillSlug}
  data-skill-name={skillName}
  data-skill-description={skillDescription}
  data-skill-safety={skillSafety}
  data-skill-md-path={skillMdPath}
  data-skill-department={department}
>
  <div class="c-head">
    <div>
      <span class="c-eyebrow">Customise for your organisation</span>
      <h2 id="customiser-title" class="c-title">
        <code>{skillName}</code>
      </h2>
    </div>
    <button class="c-close" type="button" aria-label="Close" data-close>×</button>
  </div>

  <!-- FORM STATE -->
  <form class="c-body c-state-form" id="c-form" data-state="form">
    <div class="c-intro">
      <p>
        The LLM will rewrite this skill for your environment. Your API key and form inputs
        stay in your browser — only the skill and your environment go to OpenRouter.
      </p>
      <p class="muted" id="c-key-status"></p>
    </div>

    <div class="field">
      <label for="c-tech-stack">Your tech stack</label>
      <input
        type="text"
        id="c-tech-stack"
        placeholder="EKS on AWS, Python/FastAPI, Postgres, GitHub Actions"
      />
      <p class="hint">One line. Be specific — cloud, language, framework, orchestrator.</p>
    </div>

    <div class="field">
      <label for="c-scale">Scale</label>
      <select id="c-scale">
        <option value="unspecified">(unspecified)</option>
        <option value="personal">Personal project</option>
        <option value="startup">Startup (≤50)</option>
        <option value="scaleup">Scaleup (50–500)</option>
        <option value="enterprise">Enterprise (500+)</option>
      </select>
    </div>

    <div class="field">
      <label for="c-constraints">Constraints / quirks</label>
      <textarea
        id="c-constraints"
        rows="3"
        placeholder="SOC2 Type II; all secrets via Vault; deploy via ArgoCD; no public cloud beyond AWS"
      ></textarea>
    </div>

    <div class="field">
      <label for="c-extra">Anything else?</label>
      <textarea
        id="c-extra"
        rows="3"
        placeholder="Also add a step for Istio service mesh. Skip the blue-green section — we use canary only."
      ></textarea>
      <p class="hint">Free text that steers the rewrite. Leave blank if nothing specific.</p>
    </div>

    <div class="c-meta-row">
      <div class="c-cost" id="c-cost">
        <span class="muted">cost estimate:</span>
        <code id="c-cost-value">—</code>
      </div>
      <div class="c-model muted" id="c-model-summary"></div>
    </div>

    <div class="c-actions">
      <button type="button" class="btn btn-ghost" data-close>Cancel</button>
      <button type="submit" class="btn btn-primary" id="c-submit">
        Customise with LLM
      </button>
    </div>
  </form>

  <!-- GENERATING STATE -->
  <div class="c-body c-state-generating" id="c-generating" hidden data-state="generating">
    <div class="c-gen-head">
      <div class="spinner" aria-hidden="true"></div>
      <div>
        <div class="c-gen-title">Generating…</div>
        <div class="c-gen-sub muted" id="c-gen-sub">Contacting OpenRouter…</div>
      </div>
      <button type="button" class="btn btn-ghost" id="c-cancel">Cancel</button>
    </div>
    <pre class="c-stream" id="c-stream" aria-live="polite"></pre>
  </div>

  <!-- DONE STATE -->
  <div class="c-body c-state-done" id="c-done" hidden data-state="done">
    <div id="c-done-head" class="c-done-head"></div>
    <div id="c-diff-mount" class="c-diff-mount"></div>
    <div class="c-actions">
      <button type="button" class="btn btn-ghost" id="c-back">Edit and re-run</button>
      <button type="button" class="btn btn-ghost" id="c-save">Save to browser</button>
      <button type="button" class="btn btn-ghost" id="c-copy">Copy install command</button>
      <button type="button" class="btn btn-primary" id="c-download">Download zip</button>
    </div>
  </div>

  <!-- ERROR STATE (inline, re-uses the form body) -->
</dialog>

<style>
  .customiser {
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg);
    color: var(--fg);
    width: min(52rem, 100vw - 2rem);
    max-height: calc(100vh - 4rem);
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.6);
  }
  .customiser::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
  }

  .c-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--border);
    background: var(--bg-elev-1);
  }
  .c-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .c-title {
    margin: var(--space-1) 0 0;
    font-size: 1.1rem;
    font-family: var(--font-mono);
  }
  .c-title code {
    background: transparent;
    border: 0;
    padding: 0;
    font-weight: 600;
  }
  .c-close {
    background: transparent;
    border: 0;
    color: var(--fg-muted);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.5rem;
  }
  .c-close:hover {
    color: var(--fg);
  }

  .c-body {
    padding: var(--space-5) var(--space-6);
    max-height: calc(100vh - 10rem);
    overflow-y: auto;
  }
  .c-intro {
    margin-bottom: var(--space-4);
    font-size: 0.95rem;
  }
  .c-intro p {
    margin: 0 0 var(--space-2);
  }

  .field {
    margin: var(--space-4) 0;
  }
  .field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: var(--space-2);
  }
  .customiser input[type="text"],
  .customiser select,
  .customiser textarea {
    width: 100%;
    font: inherit;
    font-size: 0.9rem;
    padding: 0.55rem 0.85rem;
    background: var(--bg-elev-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg);
  }
  .customiser input:focus,
  .customiser select:focus,
  .customiser textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg-elev-2);
  }
  .customiser textarea {
    resize: vertical;
    font-family: var(--font-sans);
  }
  .customiser .hint {
    margin: var(--space-2) 0 0;
    font-size: 0.8rem;
    color: var(--fg-muted);
  }

  .c-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--border);
    margin-top: var(--space-5);
    font-size: 0.85rem;
  }
  .c-cost code {
    font-size: 0.95em;
  }

  .c-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding-top: var(--space-4);
    margin-top: var(--space-3);
    border-top: 1px solid var(--border);
  }
  .customiser .btn {
    font: inherit;
    font-size: 0.9rem;
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--fg);
    cursor: pointer;
  }
  .customiser .btn-primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }
  .customiser .btn-primary:hover {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }
  .customiser .btn-ghost {
    color: var(--fg-muted);
    border-color: var(--border);
  }
  .customiser .btn-ghost:hover {
    color: var(--fg);
  }
  .customiser .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Generating state */
  .c-gen-head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .c-gen-title {
    font-weight: 600;
  }
  .c-gen-sub {
    font-size: 0.85rem;
    margin-top: 0.2em;
  }
  .c-gen-head .btn {
    margin-left: auto;
  }
  .spinner {
    width: 1.1rem;
    height: 1.1rem;
    border: 2px solid var(--border-strong);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .c-stream {
    margin: var(--space-4) 0 0;
    padding: var(--space-4);
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.55;
    max-height: 22rem;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Done state */
  .c-done-head {
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }
  .c-diff-mount {
    min-height: 14rem;
  }

  /* Focus visibility */
  .customiser :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>

<script>
  import { getSettings } from "@/lib/settings";
  import { getModelById, estimateCostUsd, formatCostRange } from "@/lib/models";

  /**
   * Boot the customizer modal. This commit wires up:
   *   - open / close triggers
   *   - form prefill from localStorage
   *   - cost estimate updates when inputs change
   *   - state switching (form <-> generating <-> done)
   *   - stub submit handler that just logs for now
   *
   * Commit 6 replaces the submit handler with a real OpenRouter call
   * and the diff view renderer.
   */
  function boot() {
    const dialog = document.querySelector<HTMLDialogElement>("dialog.customiser");
    if (!dialog) return;

    const form = dialog.querySelector<HTMLFormElement>("#c-form");
    const keyStatus = dialog.querySelector<HTMLElement>("#c-key-status");
    const techInput = dialog.querySelector<HTMLInputElement>("#c-tech-stack");
    const scaleInput = dialog.querySelector<HTMLSelectElement>("#c-scale");
    const constraintsInput = dialog.querySelector<HTMLTextAreaElement>("#c-constraints");
    const extraInput = dialog.querySelector<HTMLTextAreaElement>("#c-extra");
    const costValue = dialog.querySelector<HTMLElement>("#c-cost-value");
    const modelSummary = dialog.querySelector<HTMLElement>("#c-model-summary");
    const submitBtn = dialog.querySelector<HTMLButtonElement>("#c-submit");
    if (!form) return;

    // Openers
    document.querySelectorAll<HTMLElement>("[data-open-customizer]").forEach((el) => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        openDialog();
      });
    });

    // Closers
    dialog.querySelectorAll<HTMLElement>("[data-close]").forEach((el) => {
      el.addEventListener("click", () => dialog.close());
    });

    // Close when clicking outside the dialog box (on the backdrop).
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    function openDialog() {
      prefill();
      switchState("form");
      if (typeof dialog!.showModal === "function") {
        dialog!.showModal();
      } else {
        dialog!.setAttribute("open", "");
      }
      // Push focus into the first input after paint.
      setTimeout(() => techInput?.focus(), 0);
    }

    function prefill() {
      const s = getSettings();
      if (techInput) techInput.value = s.environment.techStack;
      if (scaleInput) scaleInput.value = s.environment.scale;
      if (constraintsInput) constraintsInput.value = s.environment.constraints;
      if (extraInput) extraInput.value = "";

      // Key-configured hint
      if (keyStatus) {
        if (!s.apiKey) {
          keyStatus.innerHTML =
            '⚠ No OpenRouter API key configured. <a href="/settings">Add one in Settings →</a>';
          keyStatus.style.color = "var(--warning)";
          if (submitBtn) submitBtn.disabled = true;
        } else {
          keyStatus.innerHTML = "";
          keyStatus.style.color = "";
          if (submitBtn) submitBtn.disabled = false;
        }
      }

      // Model summary + cost
      const model = getModelById(s.modelId) ?? getModelById("anthropic/claude-3.5-sonnet")!;
      if (modelSummary) {
        modelSummary.innerHTML = `model: <code>${model.label}</code> · <a href="/settings">change</a>`;
      }
      updateCost(model);
    }

    function updateCost(model = getModelById(getSettings().modelId)) {
      if (!costValue || !model) return;
      const formText = [
        techInput?.value ?? "",
        scaleInput?.value ?? "",
        constraintsInput?.value ?? "",
        extraInput?.value ?? "",
      ].join(" ");
      const skillMdChars = skillMdCharCount();
      const range = estimateCostUsd(model, {
        skillMdChars,
        formChars: formText.length,
      });
      costValue.textContent = formatCostRange(range);
    }

    [techInput, scaleInput, constraintsInput, extraInput].forEach((el) => {
      el?.addEventListener("input", () => updateCost());
    });

    /**
     * The SKILL.md content isn't loaded into this page (the per-skill
     * Astro page embeds it via the content collection render). Reading
     * a character count from the server-rendered HTML is a fine
     * estimate for cost purposes — just count the text in the
     * .skill-body element.
     */
    function skillMdCharCount(): number {
      const body = document.querySelector<HTMLElement>(".skill-body");
      if (!body) return 10_000; // fallback
      return body.innerText.length;
    }

    function switchState(state: "form" | "generating" | "done") {
      dialog!.querySelectorAll<HTMLElement>("[data-state]").forEach((el) => {
        el.hidden = el.dataset.state !== state;
      });
    }

    // Stub submit — real LLM call lands in commit 6.
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const settings = getSettings();
      if (!settings.apiKey) {
        window.location.href = "/settings";
        return;
      }
      // Placeholder — commit 6 replaces this with runCompletion(...)
      switchState("generating");
      const stream = dialog!.querySelector<HTMLElement>("#c-stream");
      if (stream) stream.textContent = "[customizer wiring lands in the next commit]";
    });

    // Cancel button (generating state) — stub until commit 6 provides an AbortController.
    dialog.querySelector<HTMLButtonElement>("#c-cancel")?.addEventListener("click", () => {
      switchState("form");
    });

    dialog.querySelector<HTMLButtonElement>("#c-back")?.addEventListener("click", () => {
      switchState("form");
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
</script>
