---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<nav aria-label="Primary">
  <div class="nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark">sk</span>
      <span class="brand-text">skillkit<span class="brand-dim">.dev</span></span>
    </a>
    <ul class="nav-links">
      <li>
        <a href="/" class:list={{ active: isActive("/") }}>Catalog</a>
      </li>
      <li>
        <a href="/departments" class:list={{ active: isActive("/departments") }}>Departments</a>
      </li>
      <li>
        <a
          href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas"
          target="_blank"
          rel="noopener">GitHub ↗</a
        >
      </li>
    </ul>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: saturate(1.2) blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }
  @media (min-width: 48rem) {
    .nav-inner {
      padding: var(--space-3) var(--space-6);
    }
  }
  .brand {
    text-decoration: none;
    color: var(--fg);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-sm);
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .brand-dim {
    color: var(--fg-muted);
    font-weight: 500;
  }
  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-6);
    font-size: 0.95rem;
  }
  .nav-links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-weight: 500;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--fg);
  }
</style>
