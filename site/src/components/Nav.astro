---
import Search from "@/components/Search.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<nav aria-label="Primary">
  <div class="nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">
        <img src="/favicon.svg" alt="" width="28" height="28" />
      </span>
      <span class="brand-text">skillskit<span class="brand-dim">.dev</span></span>
    </a>

    <ul class="nav-links">
      <li>
        <a href="/" class:list={{ active: isActive("/") }}>Catalog</a>
      </li>
      <li>
        <a href="/departments" class:list={{ active: isActive("/departments") }}>Departments</a>
      </li>
      <li>
        <a href="/settings" class:list={{ active: isActive("/settings") }}>Settings</a>
      </li>
      <li>
        <a
          href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas"
          target="_blank"
          rel="noopener">GitHub ↗</a
        >
      </li>
    </ul>

    <div class="nav-search">
      <Search variant="nav" />
    </div>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: saturate(1.2) blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }
  @media (min-width: 48rem) {
    .nav-inner {
      padding: var(--space-3) var(--space-6);
      gap: var(--space-6);
    }
  }
  .brand {
    text-decoration: none;
    color: var(--fg);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
  }
  .brand-mark img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .brand-dim {
    color: var(--fg-muted);
    font-weight: 500;
  }

  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0 auto 0 0;        /* links sit left, next to brand */
    margin-left: var(--space-6);
    display: flex;
    gap: var(--space-5);
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .nav-links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 120ms ease;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--fg);
  }
  .nav-links a.active {
    position: relative;
  }
  .nav-links a.active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 2px;
    border-radius: 2px;
    background: var(--accent);
  }

  .nav-search {
    margin-left: auto;         /* push the search icon to the far right */
    position: relative;
  }

  /* Narrow viewports: hide the text nav links to save room; brand +
     search icon are always visible. The search panel still reaches
     every linked area via typing. */
  @media (max-width: 47.99rem) {
    .nav-links {
      display: none;
    }
  }
</style>
