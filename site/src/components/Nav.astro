---
import Search from "@/components/Search.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<nav aria-label="Primary">
  <div class="nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">
        <img src="/favicon.svg" alt="" width="28" height="28" />
      </span>
      <span class="brand-text">skillskit<span class="brand-dim">.dev</span></span>
    </a>

    <div class="nav-search">
      <Search variant="nav" />
    </div>

    <ul class="nav-links">
      <li>
        <a href="/" class:list={{ active: isActive("/") }}>Catalog</a>
      </li>
      <li>
        <a href="/departments" class:list={{ active: isActive("/departments") }}>Departments</a>
      </li>
      <li>
        <a href="/settings" class:list={{ active: isActive("/settings") }}>Settings</a>
      </li>
      <li>
        <a
          href="https://github.com/tahirraufkeeyu/software-development-agent-stack--sdas"
          target="_blank"
          rel="noopener">GitHub ↗</a
        >
      </li>
    </ul>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: saturate(1.2) blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
    display: grid;
    /* brand | centered search | links */
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-4);
  }
  @media (min-width: 48rem) {
    .nav-inner {
      padding: var(--space-3) var(--space-6);
      gap: var(--space-6);
    }
  }
  .brand {
    text-decoration: none;
    color: var(--fg);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
  }
  .brand-mark img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .brand-dim {
    color: var(--fg-muted);
    font-weight: 500;
  }

  .nav-search {
    justify-self: center;
    width: 100%;
    max-width: 28rem;
    min-width: 0;
  }

  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-6);
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .nav-links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-weight: 500;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--fg);
  }

  /* Narrow viewports: the 3-column grid gets cramped. Collapse to two
     rows — brand+links on top, search bar full-width below — so the
     search is still visible without a hamburger. */
  @media (max-width: 47.99rem) {
    .nav-inner {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "brand links"
        "search search";
      row-gap: var(--space-3);
    }
    .brand {
      grid-area: brand;
    }
    .nav-links {
      grid-area: links;
      justify-self: end;
      gap: var(--space-4);
      font-size: 0.9rem;
    }
    .nav-search {
      grid-area: search;
      max-width: none;
    }
  }
</style>
