---
/**
 * CustomiseAnimation.astro — companion to Terminal.astro.
 *
 * Shows the customization flow (form -> stream -> diff -> actions) as a
 * replayable stagger-revealed animation. Mirrors Terminal's mechanics
 * (CSS @keyframes driven by --d per line, IntersectionObserver to
 * start on visibility, prefers-reduced-motion respected) but styled
 * as a browser-chrome panel instead of a macOS terminal so the two
 * animations read as distinct halves of the same story: "Run it" and
 * "Rewrite it for your stack".
 */

type LineType =
  | "field"
  | "value"
  | "button"
  | "gen"
  | "diff-add"
  | "diff-del"
  | "diff-eq"
  | "h"
  | "action"
  | "success"
  | "blank";

interface Line {
  type: LineType;
  text?: string;
  delay?: number;
}

const script: Line[] = [
  { type: "h", text: "Customise monitoring-setup for your org" },
  { type: "blank" },

  { type: "field", text: "Tech stack" },
  { type: "value", text: "EKS on AWS · Python/FastAPI · Postgres" },

  { type: "field", text: "Scale" },
  { type: "value", text: "Scaleup (50–500)" },

  { type: "field", text: "Constraints" },
  { type: "value", text: "SOC2 Type II · Vault · ArgoCD deploys" },

  { type: "blank" },
  { type: "button", text: "▸  Customise with LLM" },
  { type: "blank" },

  { type: "gen", text: "contacting openrouter…" },
  { type: "gen", text: "streaming claude 3.5 sonnet…" },
  { type: "blank" },

  { type: "h", text: "Diff · +18 / −4" },
  { type: "diff-eq", text: "  supported-stacks:" },
  { type: "diff-eq", text: "    - prometheus+grafana+k8s" },
  { type: "diff-add", text: "    - argocd+k8s         # added for your stack" },
  { type: "diff-eq", text: "  ## Procedure" },
  { type: "diff-eq", text: "  1. Detect the stack." },
  { type: "diff-del", text: "-    - kubectl get ns monitoring 2>/dev/null" },
  { type: "diff-add", text: "+    - kubectl get applications.argoproj.io -A" },
  { type: "diff-add", text: "+    - vault kv list secret/monitoring 2>/dev/null" },

  { type: "blank" },
  { type: "action", text: "[ Edit ]  [ Save ]  [ Copy install ]  [ Download zip ◀ ]" },

  { type: "blank" },
  { type: "success", text: "✓ monitoring-setup-customised.zip" },
];

const BASE_OFFSET_MS = 120;
const STEP_MS = 260;

const withDelays = script.map((l, i) => ({
  ...l,
  computedDelay: l.delay ?? BASE_OFFSET_MS + i * STEP_MS,
}));

const totalMs = withDelays.reduce(
  (max, l) => Math.max(max, l.computedDelay + 400),
  0,
);
---

<figure class="cust-panel" data-total-ms={String(totalMs)}>
  <div class="cust-chrome" aria-hidden="true">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <span class="cust-title">skillskit.dev · Customise modal</span>
  </div>
  <div class="cust-body">
    {
      withDelays.map((l) => (
        <span
          class:list={["cust-line", `cust-${l.type}`]}
          style={`--d: ${l.computedDelay}ms`}
        >
          {l.text ?? ""}
        </span>
      ))
    }
  </div>
  <figcaption class="cust-cap">
    The customizer's actual flow. Your key, your form, your diff — runs
    browser-side against OpenRouter. <a href="/settings">Bring your own key →</a>
  </figcaption>
</figure>

<style>
  .cust-panel {
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-elev-1);
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.55);
    display: flex;
    flex-direction: column;
  }

  .cust-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elev-2);
    border-bottom: 1px solid var(--border);
  }
  .cust-chrome .dot {
    display: inline-block;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
  }
  .cust-chrome .dot.red { background: #ff5f57; }
  .cust-chrome .dot.yellow { background: #febc2e; }
  .cust-chrome .dot.green { background: #28c840; }
  .cust-title {
    margin-left: auto;
    margin-right: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-muted);
  }

  .cust-body {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--fg);
    min-height: 22rem;
    max-height: 32rem;
    overflow: hidden;
    flex: 1;
  }

  .cust-line {
    display: block;
    opacity: 0;
    transform: translateY(4px);
  }
  .cust-line.cust-blank {
    height: 0.5em;
  }

  .cust-h {
    color: var(--accent);
    font-weight: 600;
    text-transform: none;
    margin-top: 0.4em;
  }
  .cust-field {
    color: var(--fg-muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.3em;
  }
  .cust-value {
    color: var(--fg);
    padding: 0.25em 0.6em;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    display: inline-block;
    margin-top: 0.2em;
    width: calc(100% - 0.5em);
    font-size: 0.78rem;
  }
  .cust-button {
    display: inline-block;
    padding: 0.4em 0.9em;
    background: var(--accent);
    color: var(--bg);
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.78rem;
  }
  .cust-gen {
    color: var(--fg-muted);
    font-style: italic;
    font-size: 0.75rem;
  }
  .cust-diff-eq {
    color: var(--fg-muted);
    font-size: 0.76rem;
  }
  .cust-diff-add {
    color: var(--success);
    background: color-mix(in srgb, var(--success) 10%, transparent);
    border-left: 2px solid var(--success);
    padding-left: 0.4em;
    font-size: 0.76rem;
  }
  .cust-diff-del {
    color: var(--danger);
    background: color-mix(in srgb, var(--danger) 10%, transparent);
    border-left: 2px solid var(--danger);
    padding-left: 0.4em;
    font-size: 0.76rem;
  }
  .cust-action {
    color: var(--fg-muted);
    font-size: 0.75rem;
    margin-top: 0.4em;
  }
  .cust-success {
    color: var(--success);
    font-weight: 600;
    font-size: 0.78rem;
  }

  .cust-panel.playing .cust-line {
    animation: cust-appear 220ms ease forwards;
    animation-delay: var(--d);
  }

  @keyframes cust-appear {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cust-cap {
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--fg-muted);
    background: var(--bg-elev-1);
  }
  .cust-cap a {
    color: var(--accent);
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .cust-panel .cust-line {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
  }
</style>

<script>
  /**
   * Same mechanic as Terminal.astro: IntersectionObserver to start on
   * visibility, setInterval for replay with reflow reset between cycles.
   * Respects prefers-reduced-motion by rendering everything instantly.
   */
  function initCustomiseAnim() {
    const panels = document.querySelectorAll<HTMLElement>(".cust-panel");
    if (panels.length === 0) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      panels.forEach((p) => p.classList.add("playing"));
      return;
    }

    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const p = entry.target as HTMLElement;
          schedule(p);
          obs.unobserve(p);
        }
      },
      { threshold: 0.25 },
    );
    panels.forEach((p) => io.observe(p));
  }

  function schedule(p: HTMLElement) {
    const totalMs = Number(p.dataset.totalMs ?? "8000");
    const pauseMs = 3500;
    const cycleMs = totalMs + pauseMs;
    p.classList.add("playing");
    setInterval(() => {
      p.classList.remove("playing");
      void p.offsetWidth;
      p.classList.add("playing");
    }, cycleMs);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCustomiseAnim);
  } else {
    initCustomiseAnim();
  }
</script>
