{
  "name": "skillskit-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Catalog site for SDAS — browse and search Claude Code skills.",
  "scripts": {
    "predev": "tsx scripts/generate-manifest.ts",
    "prebuild": "tsx scripts/generate-manifest.ts",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist --output-subdir _pagefind",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pagefind": "^1.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
